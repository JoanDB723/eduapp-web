# Copia este archivo a .env.local y rellena los valores

# Clave pública de Supabase (la misma que usa la app móvil)
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clave de servicio — NUNCA la expongas al cliente/browser
# La encuentras en Supabase → Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# Email del implementador (tú) — solo este correo puede entrar al panel
ADMIN_EMAIL=tu@correo.com
